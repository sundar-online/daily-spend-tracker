rules_version = '2';
// ═══════════════════════════════════════════════════════
// SpendSmart — Firestore Security Rules
// Replaces Supabase Row Level Security (RLS)
// ═══════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/recurringExpenses/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/savingsGoals/{docId} {
      allow read, write: if isOwner(userId);
    }

    // All user data lives under users/{userId}/...
    // Only the authenticated owner can read or write their own data.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

  }
}
